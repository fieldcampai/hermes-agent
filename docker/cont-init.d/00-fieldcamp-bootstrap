#!/command/with-contenv sh
# FieldCamp: seed/refresh the GTM profile + brain into $HERMES_HOME, then
# DETERMINISTICALLY repair config.yaml in place (python, not sed) so a stale
# volume copy can't keep a broken config alive. Always exits 0.

DATA="${HERMES_HOME:-/opt/data}"
echo "[fieldcamp] bootstrap starting (DATA=$DATA)"

if [ -n "${GITHUB_DEPLOY_TOKEN:-}" ]; then
  AUTH="https://x-access-token:${GITHUB_DEPLOY_TOKEN}@github.com/fieldcampai"
  # best-effort refresh of distribution-owned files (config/SOUL/skills)
  rm -rf /tmp/profile
  if git clone --depth 1 "$AUTH/fieldcamp-hermes-profile" /tmp/profile 2>/dev/null; then
    [ -f /tmp/profile/config.yaml ] && cp -f /tmp/profile/config.yaml "$DATA/config.yaml"
    [ -f /tmp/profile/SOUL.md ] && cp -f /tmp/profile/SOUL.md "$DATA/SOUL.md"
    [ -d /tmp/profile/skills ] && rm -rf "$DATA/skills" && cp -a /tmp/profile/skills "$DATA/skills"
    rm -rf /tmp/profile
    echo "[fieldcamp] profile refreshed from repo"
  else
    echo "[fieldcamp] WARN: profile refresh clone failed — will repair existing config in place"
  fi
  # brain (clone once)
  [ ! -d "$DATA/brain/.git" ] && { git clone --depth 1 "$AUTH/fieldcamp-gtm-brain" "$DATA/brain" 2>/dev/null && echo "[fieldcamp] brain cloned" || echo "[fieldcamp] WARN brain clone failed"; }
else
  echo "[fieldcamp] WARN: no GITHUB_DEPLOY_TOKEN"
fi

# DETERMINISTIC in-place repair of whatever config.yaml is on the volume.
if [ -f "$DATA/config.yaml" ]; then
  python3 - "$DATA/config.yaml" <<'PYEOF'
import re, sys
p = sys.argv[1]
lines = open(p, encoding="utf-8").read().splitlines()
out = []
for l in lines:
    # quote bare @-prefixed list args (a leading @ is invalid YAML)
    l = re.sub(r'^(\s*-\s+)(@[^"\s]\S*)\s*$', r'\1"\2"', l)
    # rewrite Mac-local tool paths to image PATH commands
    l = (l.replace("/Users/jeelpatel/.local/bin/uvx", "uvx")
          .replace("/Users/jeelpatel/.local/bin/qmd", "qmd")
          .replace("/opt/homebrew/bin/pipx", "pipx"))
    out.append(l)
open(p, "w", encoding="utf-8").write("\n".join(out) + "\n")
print("[fieldcamp] config.yaml repaired in place (@-args quoted, paths fixed)")
PYEOF
fi

echo "[fieldcamp] bootstrap done"
exit 0
